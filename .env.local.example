# Copy to .env.local and fill in. .env.local is gitignored.
# Two groups: public client config (inlined into the browser bundle at BUILD time)
# and server-only secrets (NEVER prefix these with NEXT_PUBLIC).

# --- Firebase client (NEXT_PUBLIC_*) — NO surrounding quotes ---
# Safe to expose: protected by Security Rules + API-key referrer restrictions (§9).
# Firebase Console -> Project Settings -> General -> Your apps -> Web app -> Config.
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abc123

# --- Server-only (Admin SDK) ---
# Firebase Console -> Project Settings -> Service accounts -> Generate new private key.
FIREBASE_ADMIN_PROJECT_ID=your-project
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
# Wrap in double quotes here to preserve the \n escapes. admin.ts normalizes them.
# In Vercel, paste the key and keep the \n literals (no surrounding quotes).
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
